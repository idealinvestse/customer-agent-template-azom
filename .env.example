# WooCommerce
WOO_BASE_URL=https://azom.se
WOO_CONSUMER_KEY=
WOO_CONSUMER_SECRET=

# Optional per-domain overrides
# WOO_BASE_URL_SE=
# WOO_BASE_URL_NO=
# WOO_BASE_URL_DK=

# SSH
SSH_HOST=azom-vps
SSH_USER=root
SSH_PORT=22
# SSH_IDENTITY_FILE=/path/to/key

# LLM (optional in V1; template generator is default)
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Mail connector
# MAIL_PROVIDER: gmail | outlook | exchange_graph | generic_imap | generic_pop3
# ---------------------------------------------------------------------------
MAIL_PROVIDER=generic_imap
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=support@azom.se

# SMTP (generic / Gmail / Outlook app password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_PASSWORD=

# IMAP
IMAP_HOST=
IMAP_PORT=993
IMAP_USE_SSL=true

# POP3
POP3_HOST=
POP3_PORT=995
POP3_USE_SSL=true

# OAuth2 (Gmail / Outlook IMAP+SMTP XOAUTH2)
# Use either app password (MAIL_PASSWORD) OR OAuth2 tokens below.
MAIL_OAUTH_ACCESS_TOKEN=
MAIL_OAUTH_REFRESH_TOKEN=
MAIL_OAUTH_CLIENT_ID=
MAIL_OAUTH_CLIENT_SECRET=
MAIL_OAUTH_TOKEN_URL=
# Public callback URL (prod: https://your-domain/oauth/gmail/callback)
MAIL_OAUTH_REDIRECT_URI=

# Microsoft Graph / Exchange Online (MAIL_PROVIDER=exchange_graph)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_USER=
# GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# Telegram dedicated bot (V2)
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs allowed to use the bot (strongly recommended in prod)
# TELEGRAM_ALLOWED_CHAT_IDS=111111111,222222222
# Map chat_id → actor (jonatan|oscar|agent). Unmapped defaults to jonatan.
# TELEGRAM_ACTOR_MAP=111111111:jonatan,222222222:oscar

# Opt-in live integration smoke (Woo/mail/Telegram). Safe with AZOM_USE_MOCK=1.
# AZOM_LIVE_SMOKE=1
# Poll freshness for /health readiness (seconds; default 900)
# AZOM_POLL_STALE_SEC=900
# Cases Path B: force auto-send off even if config/cases_ai.yaml enables it
# AZOM_AUTO_SEND_KILL=1

# Dashboard auth (Jonatan viewer / Oscar full_admin)
DASHBOARD_USER=jonatan
DASHBOARD_PASSWORD=
# Prefer salted Werkzeug hash (pbkdf2:/scrypt:) — legacy SHA-256 hex still accepted:
# DASHBOARD_PASSWORD_HASH=
# Oscar Basic Auth (username: oscar)
DASHBOARD_OSCAR_PASSWORD=
# DASHBOARD_OSCAR_PASSWORD_HASH=
# Session/CSRF secret (required for POST forms in browser)
# DASHBOARD_SECRET_KEY=

# Runtime
# Local/dev mock: AZOM_USE_MOCK=1
# Production (Ubuntu 24 / Hetzner): AZOM_USE_MOCK=0
# Mock default passwords (jonatan/oscar) ONLY work when AZOM_USE_MOCK=1
AZOM_USE_MOCK=1
AZOM_CONFIG_DIR=./config
AZOM_DATA_DIR=./.azom-data
# Production paths (set by bootstrap-ubuntu24.sh):
# AZOM_CONFIG_DIR=/opt/azom-agent/config
# AZOM_DATA_DIR=/var/lib/azom

# Dashboard bind (systemd uses 127.0.0.1; Docker may use 0.0.0.0)
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
